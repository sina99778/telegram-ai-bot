# ═══════════════════════════════════════════════
#  Telegram AI Bot — Environment Variables
# ═══════════════════════════════════════════════
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ═══════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
WEBHOOK_URL=https://your-domain.example.com/webhook
# Generate a random secret:  python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change-me-to-a-random-string

# ── Google Gemini AI ──────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
# These match the Settings fields in app/core/config.py:
GEMINI_MODEL_NORMAL=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-3.1-pro

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=gemini_bot_db
POSTGRES_HOST=db
# Connection URL is constructed automatically in app/core/config.py

# ── Redis (ARQ background workers) ───────────
REDIS_URL=redis://redis:6379/0

# ── Admin ─────────────────────────────────────
# Comma-separated Telegram user IDs who can run /stats and other admin commands
ADMIN_IDS=123456789

# ── Payments (optional) ──────────────────────
NOWPAYMENTS_API_KEY=
