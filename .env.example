# ═══════════════════════════════════════════════
#  Telegram AI Bot — Environment Variables
# ═══════════════════════════════════════════════
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ═══════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
WEBHOOK_URL=https://yechizealakijadid.store/webhook
# Generate a random secret:  python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change-me-to-a-random-string

# ── Google Gemini AI ──────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro-latest

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=gemini_bot_db
POSTGRES_HOST=db
# Constructed automatically in app/core/config.py — shown here for reference:
# DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}

# ── Admin ─────────────────────────────────────
# Comma-separated Telegram user IDs who can run /stats and other admin commands
ADMIN_IDS=123456789

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
# REDIS_PORT=6379
